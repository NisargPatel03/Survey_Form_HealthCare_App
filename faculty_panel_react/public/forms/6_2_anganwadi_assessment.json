{
  "title": "Anganwadi Assessment Program Report",
  "institution": "Manikaka Topawala Institute of Nursing, CHARUSAT – Community Health Nursing",
  "sections": [
    {
      "section": "Student & Submission Information",
      "fields": [
        {
          "key": "student_name",
          "label": "Name of Student",
          "type": "text",
          "required": true
        },
        {
          "key": "student_id",
          "label": "Student ID No.",
          "type": "text",
          "required": true
        },
        {
          "key": "date_of_submission",
          "label": "Date of Submission",
          "type": "date",
          "required": true
        },
        {
          "key": "place",
          "label": "Place",
          "type": "text",
          "required": true
        }
      ]
    },
    {
      "section": "1. Introduction",
      "fields": [
        {
          "key": "introduction",
          "label": "Introduction",
          "type": "textarea",
          "hint": "Provide clear context and relevance of the Anganwadi Assessment Program — background, purpose, and significance",
          "required": true
        }
      ]
    },
    {
      "section": "2. Objectives",
      "fields": [
        {
          "key": "general_objective",
          "label": "General Objective",
          "type": "textarea",
          "hint": "One broad overarching objective of the Anganwadi assessment",
          "required": true
        },
        {
          "key": "specific_objectives",
          "label": "Specific Objectives",
          "type": "array",
          "itemLabel": "Objective",
          "minItems": 1,
          "hint": "List specific, measurable objectives of the assessment program",
          "required": true
        }
      ]
    },
    {
      "section": "3. Assessment of the Anganwadi Center",
      "fields": [
        {
          "key": "anganwadi_name",
          "label": "Name of Anganwadi Center",
          "type": "text",
          "required": true
        },
        {
          "key": "anganwadi_address",
          "label": "Address / Location",
          "type": "textarea",
          "required": true
        },
        {
          "key": "infrastructure_assessment",
          "label": "Infrastructure Assessment",
          "type": "textarea",
          "hint": "Describe building condition, rooms, ventilation, lighting, flooring, roof, and overall physical state",
          "required": true
        },
        {
          "key": "accessibility",
          "label": "Accessibility",
          "type": "textarea",
          "hint": "Describe how accessible the center is — roads, distance from community, transport availability",
          "required": true
        },
        {
          "key": "sanitation_and_hygiene",
          "label": "Sanitation & Hygiene",
          "type": "textarea",
          "hint": "Describe availability of toilets, handwashing area, drinking water, and waste disposal",
          "required": true
        },
        {
          "key": "total_children_enrolled",
          "label": "Total Children Enrolled",
          "type": "number",
          "required": true
        },
        {
          "key": "total_beneficiaries",
          "label": "Total Beneficiaries (including pregnant/lactating women)",
          "type": "number",
          "required": false
        }
      ]
    },
    {
      "section": "4. Services Provided Under the Anganwadi Center",
      "fields": [
        {
          "key": "services_provided",
          "label": "ICDS Services Provided",
          "type": "array",
          "itemLabel": "Service",
          "minItems": 1,
          "hint": "List all ICDS services offered — e.g. supplementary nutrition, immunization, health checkup, pre-school education, referral, nutrition & health education",
          "required": true,
          "itemSchema": {
            "service_name": {
              "label": "Service Name",
              "type": "text",
              "required": true
            },
            "description": {
              "label": "Description / Details",
              "type": "textarea",
              "required": true
            }
          }
        }
      ]
    },
    {
      "section": "5. Staffing Pattern",
      "fields": [
        {
          "key": "staffing_pattern",
          "label": "Staffing Pattern",
          "type": "array",
          "minItems": 1,
          "hint": "List all staff at the Anganwadi center with their designation and name if available",
          "required": true,
          "itemSchema": {
            "sr_no": {
              "label": "Sr. No.",
              "type": "number",
              "required": true
            },
            "designation": {
              "label": "Designation",
              "type": "text",
              "hint": "e.g. Anganwadi Worker (AWW), Anganwadi Helper (AWH), Supervisor",
              "required": true
            },
            "name": {
              "label": "Name (if applicable)",
              "type": "text",
              "required": false
            }
          }
        }
      ]
    },
    {
      "section": "6. Physical Layout of the Center",
      "fields": [
        {
          "key": "physical_layout_description",
          "label": "Physical Layout Description",
          "type": "textarea",
          "hint": "Describe the layout of the center — rooms, play area, kitchen, storage, toilet, and their arrangement",
          "required": true
        },
        {
          "key": "physical_layout_sketch",
          "label": "Sketch / Map of Layout",
          "type": "file",
          "accept": [
            "image/png",
            "image/jpeg",
            "application/pdf"
          ],
          "hint": "Upload a hand-drawn or digital sketch of the Anganwadi center layout",
          "required": false
        }
      ]
    },
    {
      "section": "7. Weekly Schedule & Diet Menu",
      "fields": [
        {
          "key": "weekly_schedule",
          "label": "Weekly Schedule of the Anganwadi",
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "hint": "Enter activities conducted on each working day (Monday to Saturday)",
          "required": true,
          "itemSchema": {
            "day": {
              "label": "Day",
              "type": "dropdown",
              "options": [
                "Monday",
                "Tuesday",
                "Wednesday",
                "Thursday",
                "Friday",
                "Saturday"
              ],
              "required": true
            },
            "activities_conducted": {
              "label": "Activities Conducted",
              "type": "textarea",
              "required": true
            }
          }
        },
        {
          "key": "weekly_diet_menu",
          "label": "Weekly Diet Menu for Children",
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "hint": "Enter breakfast and lunch menu for each working day (Monday to Saturday)",
          "required": true,
          "itemSchema": {
            "day": {
              "label": "Day",
              "type": "dropdown",
              "options": [
                "Monday",
                "Tuesday",
                "Wednesday",
                "Thursday",
                "Friday",
                "Saturday"
              ],
              "required": true
            },
            "breakfast": {
              "label": "Breakfast",
              "type": "text",
              "required": true
            },
            "lunch": {
              "label": "Lunch",
              "type": "text",
              "required": true
            }
          }
        }
      ]
    },
    {
      "section": "8. Activities Carried Out by Nursing Students",
      "fields": [
        {
          "key": "student_activities",
          "label": "Activities Carried Out by Nursing Students",
          "type": "array",
          "itemLabel": "Activity",
          "minItems": 1,
          "hint": "List all activities performed by nursing students during the visit — health talks, demonstrations, screenings, games, etc.",
          "required": true,
          "itemSchema": {
            "activity_name": {
              "label": "Activity",
              "type": "text",
              "required": true
            },
            "description": {
              "label": "Description / Outcome",
              "type": "textarea",
              "required": true
            }
          }
        }
      ]
    },
    {
      "section": "9. Health Assessment of Anganwadi Children",
      "fields": [
        {
          "key": "health_assessment_data",
          "label": "Health Assessment Data",
          "type": "array",
          "minItems": 1,
          "hint": "Enter one row per child assessed. MUAC = Mid Upper Arm Circumference.",
          "required": true,
          "itemSchema": {
            "anganwadi_name": {
              "label": "Name of the Anganwadi",
              "type": "text",
              "required": true
            },
            "sr_no": {
              "label": "Sr. No.",
              "type": "number",
              "required": true
            },
            "name_of_child": {
              "label": "Name of Child",
              "type": "text",
              "required": true
            },
            "age": {
              "label": "Age (Yrs/Months)",
              "type": "text",
              "required": true
            },
            "gender": {
              "label": "Gender",
              "type": "dropdown",
              "options": [
                "Male",
                "Female"
              ],
              "required": true
            },
            "height_cm": {
              "label": "Height (cm)",
              "type": "number",
              "required": true
            },
            "weight_kg": {
              "label": "Weight (kg)",
              "type": "number",
              "required": true
            },
            "head_circumference_cm": {
              "label": "Head Circumference (cm)",
              "type": "number",
              "required": false
            },
            "chest_circumference_cm": {
              "label": "Chest Circumference (cm)",
              "type": "number",
              "required": false
            },
            "muac_cm": {
              "label": "Mid Upper Arm Circumference – MUAC (cm)",
              "type": "number",
              "required": false
            },
            "degree_of_malnutrition": {
              "label": "Degree of Malnutrition",
              "type": "dropdown",
              "options": [
                "Normal",
                "Grade I (Mild)",
                "Grade II (Moderate)",
                "Grade III (Severe)",
                "Grade IV (Very Severe)",
                "SAM (Severe Acute Malnutrition)",
                "MAM (Moderate Acute Malnutrition)"
              ],
              "required": false
            },
            "remarks": {
              "label": "Remarks",
              "type": "text",
              "hint": "e.g. Referred, Under treatment, Immunization pending",
              "required": false
            }
          }
        },
        {
          "key": "common_problems_identified",
          "label": "Common Problems Identified Among Anganwadi Children",
          "type": "array",
          "minItems": 1,
          "maxItems": 15,
          "hint": "Summarize conditions found, with count and percentage of affected children",
          "required": true,
          "itemSchema": {
            "sr_no": {
              "label": "Sr. No.",
              "type": "number",
              "required": true
            },
            "condition": {
              "label": "Condition",
              "type": "text",
              "hint": "e.g. Underweight, Stunting, Wasting, Anaemia, Skin infection, Diarrhoea",
              "required": true
            },
            "number_of_problems_identified": {
              "label": "Number of Problems Identified",
              "type": "number",
              "required": true
            },
            "percentage": {
              "label": "Percentage (%)",
              "type": "number",
              "required": true
            }
          }
        }
      ]
    },
    {
      "section": "10. Conclusion and Summary",
      "fields": [
        {
          "key": "conclusion",
          "label": "Conclusion",
          "type": "textarea",
          "hint": "Summarize the key findings from the Anganwadi assessment",
          "required": true
        },
        {
          "key": "summary",
          "label": "Summary",
          "type": "textarea",
          "hint": "Reflect on personal learning, observations, and recommendations from the program",
          "required": true
        }
      ]
    },
    {
      "section": "Evaluation (For Evaluator Use Only)",
      "fields": [
        {
          "key": "marks",
          "label": "Marks",
          "type": "object",
          "required": false,
          "properties": {
            "introduction": {
              "label": "Introduction (clear context and relevance)",
              "max_marks": 5
            },
            "objectives": {
              "label": "Objectives (general and specific objectives defined)",
              "max_marks": 5
            },
            "anganwadi_assessment": {
              "label": "Assessment of Anganwadi (infrastructure and accessibility)",
              "max_marks": 5
            },
            "services_provided": {
              "label": "Services Provided (detailed and accurate listing of ICDS services)",
              "max_marks": 5
            },
            "staffing_pattern": {
              "label": "Staffing Pattern (worker/helper roles correctly mentioned)",
              "max_marks": 5
            },
            "layout_and_schedule": {
              "label": "Physical Layout & Schedule (layout understanding, weekly planning)",
              "max_marks": 5
            },
            "weekly_diet_menu": {
              "label": "Weekly Diet Menu (appropriate, nutritious, and varied)",
              "max_marks": 5
            },
            "student_activities": {
              "label": "Student Activities (active involvement and variety)",
              "max_marks": 5
            },
            "health_assessment": {
              "label": "Health Assessment of Children (accurate screening and interpretation)",
              "max_marks": 5
            },
            "conclusion_and_summary": {
              "label": "Conclusion and Summary (clarity in findings and reflection)",
              "max_marks": 5
            },
            "total": {
              "label": "Total",
              "max_marks": 50
            }
          }
        }
      ]
    }
  ]
}