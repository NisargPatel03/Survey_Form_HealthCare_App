{
  "title": "School Health Program Report",
  "institution": "Manikaka Topawala Institute of Nursing, CHARUSAT – Community Health Nursing",
  "sections": [
    {
      "section": "Student & Submission Information",
      "fields": [
        {
          "key": "student_name",
          "label": "Name of Student",
          "type": "text",
          "required": true
        },
        {
          "key": "student_id",
          "label": "Student ID No.",
          "type": "text",
          "required": true
        },
        {
          "key": "date_of_submission",
          "label": "Date of Submission",
          "type": "date",
          "required": true
        },
        {
          "key": "place",
          "label": "Place",
          "type": "text",
          "required": true
        }
      ]
    },
    {
      "section": "1. Introduction",
      "fields": [
        {
          "key": "introduction",
          "label": "Introduction",
          "type": "textarea",
          "hint": "Provide a clear background, rationale, and basic event details of the school health program",
          "required": true
        }
      ]
    },
    {
      "section": "2. Assessment of the School",
      "fields": [
        {
          "key": "school_name",
          "label": "Name of School",
          "type": "text",
          "required": true
        },
        {
          "key": "school_address",
          "label": "Address of School",
          "type": "textarea",
          "required": true
        },
        {
          "key": "type_of_school",
          "label": "Type of School",
          "type": "dropdown",
          "options": [
            "Government",
            "Private",
            "Semi-Government",
            "Aided",
            "Other"
          ],
          "required": true
        },
        {
          "key": "total_students",
          "label": "Total Number of Students",
          "type": "number",
          "required": true
        },
        {
          "key": "total_staff",
          "label": "Total Number of Staff",
          "type": "number",
          "required": false
        },
        {
          "key": "environmental_assessment",
          "label": "Environmental Assessment",
          "type": "textarea",
          "hint": "Describe the school surroundings, open spaces, ventilation, lighting, and general cleanliness",
          "required": true
        },
        {
          "key": "hygiene_assessment",
          "label": "Hygiene & Sanitation Assessment",
          "type": "textarea",
          "hint": "Describe availability and condition of toilets, handwashing facilities, drinking water, waste disposal",
          "required": true
        },
        {
          "key": "health_infrastructure",
          "label": "Health Infrastructure",
          "type": "textarea",
          "hint": "Describe availability of sick room, first aid kit, health records, school health nurse/doctor",
          "required": true
        }
      ]
    },
    {
      "section": "3. Planning of the Program",
      "fields": [
        {
          "key": "planning_details",
          "label": "Planning Details",
          "type": "textarea",
          "hint": "Describe the planning steps taken — objectives set, team formation, resource allocation, schedule preparation",
          "required": true
        },
        {
          "key": "program_objectives",
          "label": "Objectives of the Program",
          "type": "array",
          "itemLabel": "Objective",
          "minItems": 1,
          "required": true
        },
        {
          "key": "resources_used",
          "label": "Resources Used",
          "type": "textarea",
          "hint": "List materials, equipment, manpower, and AV aids arranged for the program",
          "required": true
        },
        {
          "key": "date_of_program",
          "label": "Date of Program",
          "type": "date",
          "required": true
        },
        {
          "key": "time_of_program",
          "label": "Time of Program",
          "type": "time",
          "required": true
        }
      ]
    },
    {
      "section": "4. Execution of the Program",
      "fields": [
        {
          "key": "execution_details",
          "label": "Execution of the Program",
          "type": "textarea",
          "hint": "Describe the logical flow of activities, student participation, real-time handling of events, and how the program was carried out",
          "required": true
        }
      ]
    },
    {
      "section": "5. Role of Nursing Students",
      "fields": [
        {
          "key": "role_of_nursing_students",
          "label": "Role of Nursing Students",
          "type": "textarea",
          "hint": "Clearly describe the involvement of nursing students — activities performed, responsibilities handled, skills demonstrated, and learning outcomes",
          "required": true
        }
      ]
    },
    {
      "section": "6. Health Screening Components",
      "fields": [
        {
          "key": "screening_components",
          "label": "Health Screening Components",
          "type": "array",
          "itemLabel": "Component",
          "minItems": 1,
          "hint": "List and describe each screening activity conducted (e.g. vision, dental, skin, nutritional assessment)",
          "required": true,
          "itemSchema": {
            "component_name": {
              "label": "Screening Component",
              "type": "text",
              "hint": "e.g. Vision Screening, Dental Checkup, Skin Assessment, BMI Measurement",
              "required": true
            },
            "description": {
              "label": "Description / Findings",
              "type": "textarea",
              "required": true
            }
          }
        }
      ]
    },
    {
      "section": "7. Health Assessment Data of School Children",
      "fields": [
        {
          "key": "health_assessment_data",
          "label": "Health Assessment of School Children",
          "type": "array",
          "minItems": 1,
          "hint": "Enter one row per child assessed. Stunting and wasting percentages are calculated based on WHO growth standards.",
          "required": true,
          "itemSchema": {
            "sr_no": {
              "label": "Sr. No.",
              "type": "number",
              "required": true
            },
            "std": {
              "label": "Standard (Class)",
              "type": "text",
              "hint": "e.g. 5th, 6th, 7th",
              "required": true
            },
            "name_of_student": {
              "label": "Name of Student",
              "type": "text",
              "required": true
            },
            "age_yrs": {
              "label": "Age (Yrs)",
              "type": "number",
              "required": true
            },
            "height_cm": {
              "label": "Height (cm)",
              "type": "number",
              "required": true
            },
            "weight_kg": {
              "label": "Weight (kg)",
              "type": "number",
              "required": true
            },
            "stunting_percent": {
              "label": "Stunting (%)",
              "type": "number",
              "required": false
            },
            "wasting_percent": {
              "label": "Wasting (%)",
              "type": "number",
              "required": false
            },
            "stunting_remarks": {
              "label": "Stunting Remarks",
              "type": "text",
              "hint": "e.g. Normal, Moderate Stunting, Severe Stunting",
              "required": false
            },
            "wasting_remarks": {
              "label": "Wasting Remarks",
              "type": "text",
              "hint": "e.g. Normal, Moderate Wasting, Severe Wasting",
              "required": false
            },
            "others_remarks": {
              "label": "Other Remarks",
              "type": "text",
              "hint": "e.g. skin problem, dental caries, vision issue, referred",
              "required": false
            }
          }
        },
        {
          "key": "common_problems_identified",
          "label": "Common Problems Identified Among School Children",
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "hint": "Summarize the common health conditions found, with frequency count and percentage",
          "required": true,
          "itemSchema": {
            "sr_no": {
              "label": "Sr. No.",
              "type": "number",
              "required": true
            },
            "condition": {
              "label": "Condition",
              "type": "text",
              "hint": "e.g. Dental Caries, Anaemia, Skin Infection, Visual Defect",
              "required": true
            },
            "frequency": {
              "label": "Frequency",
              "type": "number",
              "required": true
            },
            "percentage": {
              "label": "Percentage (%)",
              "type": "number",
              "required": true
            }
          }
        }
      ]
    },
    {
      "section": "8. Outcome of the School Health Program",
      "fields": [
        {
          "key": "outcome",
          "label": "Outcome of the School Health Program",
          "type": "textarea",
          "hint": "Reflect on results achieved, referrals made, feedback received from students/teachers, and overall impact of the program",
          "required": true
        }
      ]
    },
    {
      "section": "9. Conclusion and Summary",
      "fields": [
        {
          "key": "conclusion",
          "label": "Conclusion",
          "type": "textarea",
          "hint": "Provide a meaningful synthesis of all findings and activities",
          "required": true
        },
        {
          "key": "summary",
          "label": "Summary",
          "type": "textarea",
          "hint": "Highlight the key learning takeaways from the school health program experience",
          "required": true
        }
      ]
    },
    {
      "section": "Evaluation (For Evaluator Use Only)",
      "fields": [
        {
          "key": "marks",
          "label": "Marks",
          "type": "object",
          "required": false,
          "properties": {
            "introduction": {
              "label": "Introduction (background, rationale, event details)",
              "max_marks": 5
            },
            "school_assessment": {
              "label": "School Assessment (environmental, hygiene, health infrastructure)",
              "max_marks": 5
            },
            "planning_and_preparation": {
              "label": "Planning and Preparation (planning steps, teamwork, resource readiness)",
              "max_marks": 5
            },
            "execution_process": {
              "label": "Execution Process (logical flow, participation, real-time handling)",
              "max_marks": 10
            },
            "role_of_nursing_students": {
              "label": "Role of Nursing Students (clarity and extent of involvement and learning)",
              "max_marks": 5
            },
            "health_screening": {
              "label": "Health Screening Components (appropriateness and completeness)",
              "max_marks": 5
            },
            "assessment_data": {
              "label": "Assessment Data Presentation (table clarity, accuracy, interpretation)",
              "max_marks": 5
            },
            "outcome_reporting": {
              "label": "Outcome Reporting (results, referrals, feedback, impact)",
              "max_marks": 5
            },
            "conclusion_and_summary": {
              "label": "Conclusion and Summary (synthesis of findings and key takeaways)",
              "max_marks": 5
            },
            "total": {
              "label": "Total",
              "max_marks": 50
            }
          }
        }
      ]
    }
  ]
}