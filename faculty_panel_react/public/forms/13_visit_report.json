{
  "title": "Visit Report",
  "institution": "Manikaka Topawala Institute of Nursing, CHARUSAT – Community Health Nursing",
  "sections": [
    {
      "section": "Student & Submission Information",
      "fields": [
        {
          "key": "student_name",
          "label": "Name of Student",
          "type": "text",
          "required": true
        },
        {
          "key": "class_semester",
          "label": "Class / Semester",
          "type": "text",
          "required": true
        },
        {
          "key": "student_id",
          "label": "Student ID No.",
          "type": "text",
          "required": true
        },
        {
          "key": "name_of_centre",
          "label": "Name of Centre",
          "type": "text",
          "required": true
        },
        {
          "key": "location",
          "label": "Location",
          "type": "text",
          "required": true
        },
        {
          "key": "date_of_visit",
          "label": "Date of Visit",
          "type": "date",
          "required": true
        },
        {
          "key": "date_of_submission",
          "label": "Date of Submission",
          "type": "date",
          "required": true
        }
      ]
    },
    {
      "section": "1. Introduction",
      "fields": [
        {
          "key": "introduction",
          "label": "Introduction",
          "type": "textarea",
          "hint": "Briefly describe the purpose of the visit — why it was conducted, which centre was visited, and what was expected to be learned",
          "required": true
        }
      ]
    },
    {
      "section": "2. Objectives of the Visit",
      "fields": [
        {
          "key": "general_objective",
          "label": "A. General Objective",
          "type": "textarea",
          "hint": "State the broad overall goal of the visit",
          "required": true
        },
        {
          "key": "specific_objectives",
          "label": "B. Specific Objectives",
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "itemLabel": "Objective",
          "hint": "List the specific, measurable objectives of the visit",
          "required": true
        }
      ]
    },
    {
      "section": "3. Physical Layout of Centre",
      "fields": [
        {
          "key": "physical_layout_description",
          "label": "Physical Layout Description",
          "type": "textarea",
          "hint": "Describe the physical layout of the centre — buildings, wards, rooms, outdoor areas, entry/exit points, and overall structure",
          "required": true
        },
        {
          "key": "layout_sketch_or_map",
          "label": "Sketch / Map of Layout",
          "type": "sketch",
          "accept": [
            "image/png",
            "image/jpeg"
          ],
          "hint": "Draw or upload a sketch of the center layout",
          "required": false
        }
      ]
    },
    {
      "section": "4. Staffing Pattern",
      "fields": [
        {
          "key": "staffing_pattern",
          "label": "Staffing Pattern",
          "type": "array",
          "minItems": 1,
          "required": true,
          "hint": "List the categories of staff and their numbers at the centre",
          "itemSchema": {
            "sr_no": {
              "label": "Sr. No.",
              "type": "number",
              "required": true
            },
            "designation": {
              "label": "Designation / Role",
              "type": "text",
              "hint": "e.g. Medical Officer, Staff Nurse, ANM, ASHA, Pharmacist",
              "required": true
            },
            "number_of_staff": {
              "label": "Number of Staff",
              "type": "number",
              "required": true
            },
            "remarks": {
              "label": "Remarks",
              "type": "text",
              "required": false
            }
          }
        }
      ]
    },
    {
      "section": "5. Departments and Services Offered",
      "fields": [
        {
          "key": "departments_and_services",
          "label": "Departments and Services",
          "type": "array",
          "minItems": 1,
          "required": true,
          "hint": "List each department and describe its main functions and services offered",
          "itemSchema": {
            "sr_no": {
              "label": "Sr. No.",
              "type": "number",
              "required": true
            },
            "department_name": {
              "label": "Department Name",
              "type": "text",
              "required": true
            },
            "functions_and_services": {
              "label": "Main Functions & Services",
              "type": "textarea",
              "required": true
            }
          }
        }
      ]
    },
    {
      "section": "6. Records and Reports Maintained",
      "fields": [
        {
          "key": "records_and_reports",
          "label": "Records and Reports Maintained",
          "type": "array",
          "minItems": 1,
          "required": true,
          "hint": "List the records and reports maintained at the centre along with their purpose",
          "itemSchema": {
            "sr_no": {
              "label": "Sr. No.",
              "type": "number",
              "required": true
            },
            "record_report_name": {
              "label": "Name of Record / Report",
              "type": "text",
              "required": true
            },
            "purpose": {
              "label": "Purpose",
              "type": "textarea",
              "required": true
            }
          }
        }
      ]
    },
    {
      "section": "7. Conclusion",
      "fields": [
        {
          "key": "conclusion",
          "label": "Conclusion",
          "type": "textarea",
          "hint": "Summarize the learning outcomes and personal reflections from the visit — what was observed, learned, and how it relates to community health nursing practice",
          "required": true
        }
      ]
    },
    {
      "section": "8. References",
      "fields": [
        {
          "key": "references",
          "label": "References",
          "type": "array",
          "minItems": 1,
          "itemLabel": "Reference",
          "hint": "List all references, textbooks, and sources consulted for the report",
          "required": true
        }
      ]
    },
    {
      "section": "Evaluation (For Evaluator Use Only)",
      "fields": [
        {
          "key": "marks",
          "label": "Evaluation Criteria",
          "type": "object",
          "required": false,
          "properties": {
            "introduction_and_objectives": {
              "label": "Introduction and Objectives",
              "max_marks": 5
            },
            "physical_layout_description": {
              "label": "Physical Layout Description",
              "max_marks": 5
            },
            "staffing_pattern": {
              "label": "Staffing Pattern",
              "max_marks": 5
            },
            "services_and_departmental_details": {
              "label": "Services and Departmental Details",
              "max_marks": 5
            },
            "records_and_reports_maintained": {
              "label": "Records and Reports Maintained",
              "max_marks": 5
            },
            "conclusion_and_references": {
              "label": "Conclusion and References",
              "max_marks": 5
            },
            "total": {
              "label": "Total",
              "max_marks": 30
            }
          }
        }
      ]
    }
  ]
}