{
  "title": "Orientation Report",
  "institution": "Manikaka Topawala Institute of Nursing, CHARUSAT – Department of Community Health Nursing",
  "sections": [
    {
      "section": "Student Information",
      "fields": [
        {
          "key": "student_name",
          "label": "Name of Student",
          "type": "text",
          "required": true
        },
        {
          "key": "student_id",
          "label": "Student ID No.",
          "type": "text",
          "required": true
        },
        {
          "key": "class_semester",
          "label": "Class / Semester",
          "type": "text",
          "required": true
        },
        {
          "key": "center_name",
          "label": "Name of Centre",
          "type": "text",
          "required": true
        },
        {
          "key": "center_type",
          "label": "Type of Center",
          "type": "dropdown",
          "options": [
            "Sub-Center (SC)",
            "Primary Health Center (PHC)",
            "Community Health Center (CHC)",
            "Health and Wellness Center (HWCs)",
            "Anganwadi"
          ],
          "required": true
        },
        {
          "key": "location",
          "label": "Location",
          "type": "text",
          "required": true
        },
        {
          "key": "date_of_orientation",
          "label": "Date of Orientation",
          "type": "date",
          "required": true
        },
        {
          "key": "date_of_submission",
          "label": "Date of Submission",
          "type": "date",
          "required": true
        }
      ]
    },
    {
      "section": "1. Introduction",
      "fields": [
        {
          "key": "introduction",
          "label": "Introduction (Briefly describe the purpose of the orientation visit)",
          "type": "textarea",
          "required": true
        }
      ]
    },
    {
      "section": "2. Objectives of the Orientation",
      "fields": [
        {
          "key": "general_objective",
          "label": "A. General Objective",
          "type": "textarea",
          "required": true
        },
        {
          "key": "specific_objectives",
          "label": "B. Specific Objectives",
          "type": "array",
          "itemLabel": "Specific Objective",
          "hint": "List each specific objective separately",
          "required": true
        }
      ]
    },
    {
      "section": "3. Physical Layout of Centre",
      "fields": [
        {
          "key": "physical_layout_description",
          "label": "Description of Physical Layout",
          "type": "textarea",
          "required": true
        },
        {
          "key": "physical_layout_sketch",
          "label": "Sketch / Map of Layout",
          "type": "sketch",
          "accept": [
            "image/png",
            "image/jpeg",
            "application/pdf"
          ],
          "required": false
        }
      ]
    },
    {
      "section": "4. Staffing Pattern",
      "fields": [
        {
          "key": "staffing_pattern",
          "label": "Staffing Pattern",
          "type": "array",
          "minItems": 1,
          "required": true,
          "hint": "List the categories of staff and their numbers at the centre",
          "itemSchema": {
            "sr_no": {
              "label": "Sr. No.",
              "type": "number",
              "required": true
            },
            "designation": {
              "label": "Designation / Role",
              "type": "text",
              "hint": "e.g. Medical Officer, Staff Nurse, ANM, ASHA, Pharmacist",
              "required": true
            },
            "number_of_staff": {
              "label": "Number of Staff",
              "type": "number",
              "required": true
            },
            "remarks": {
              "label": "Remarks",
              "type": "text",
              "required": false
            }
          }
        }
      ]
    },
    {
      "section": "5. Departments and Services Offered",
      "fields": [
        {
          "key": "departments_and_services",
          "label": "Departments and Services Offered",
          "type": "textarea",
          "hint": "List departments and describe their main functions",
          "required": true
        }
      ]
    },
    {
      "section": "6. Records and Reports Maintained",
      "fields": [
        {
          "key": "records_and_reports",
          "label": "Records and Reports Maintained",
          "type": "textarea",
          "hint": "List all registers, records, and reports observed at the centre",
          "required": true
        }
      ]
    },
    {
      "section": "7. Conclusion and References",
      "fields": [
        {
          "key": "conclusion",
          "label": "Conclusion (Summarize the learning outcomes and personal reflections)",
          "type": "textarea",
          "required": true
        },
        {
          "key": "references",
          "label": "References",
          "type": "array",
          "minItems": 3,
          "itemLabel": "Reference",
          "hint": "List all references used (books, websites, guidelines, etc.)",
          "required": true
        }
      ]
    },
    {
      "section": "Evaluation (For Evaluator Use Only)",
      "fields": [
        {
          "key": "marks",
          "label": "Evaluation Criteria",
          "type": "object",
          "properties": {
            "intro": {
              "label": "1. Introduction and Objectives",
              "max_marks": 5
            },
            "layout": {
              "label": "2. Physical Layout Description",
              "max_marks": 5
            },
            "staffing": {
              "label": "3. Staffing Pattern",
              "max_marks": 5
            },
            "services": {
              "label": "4. Services and Departmental Details",
              "max_marks": 5
            },
            "records": {
              "label": "5. Records and Reports Maintained",
              "max_marks": 5
            },
            "conclusion": {
              "label": "6. Conclusion and References",
              "max_marks": 5
            },
            "total": {
              "label": "Total",
              "max_marks": 30
            }
          }
        }
      ]
    }
  ]
}