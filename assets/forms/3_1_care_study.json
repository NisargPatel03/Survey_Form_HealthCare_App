{
  "title": "Family Care Study",
  "institution": "Manikaka Topawala Institute of Nursing, CHARUSAT – Department of Community Health Nursing",
  "sections": [
    {
      "section": "Student & Submission Information",
      "fields": [
        {
          "key": "student_name",
          "label": "Name of Student",
          "type": "text",
          "required": true
        },
        {
          "key": "student_id",
          "label": "Student ID No.",
          "type": "text",
          "required": true
        },
        {
          "key": "semester_year",
          "label": "Semester / Year",
          "type": "text",
          "required": true
        },
        {
          "key": "topic",
          "label": "Topic",
          "type": "text",
          "required": true
        },
        {
          "key": "date_of_submission",
          "label": "Date of Submission",
          "type": "date",
          "required": true
        }
      ]
    },
    {
      "section": "I. Introduction",
      "fields": [
        {
          "key": "introduction_self",
          "label": "Self Introduction",
          "type": "textarea",
          "hint": "e.g. I am [Name] from Manikaka Topawala Institute of Nursing. For the purpose of completing my care plan assignment, I have selected this case...",
          "required": true
        },
        {
          "key": "objectives_for_student",
          "label": "Objectives – For Student",
          "type": "textarea",
          "hint": "List the learning objectives from the student's perspective",
          "required": true
        },
        {
          "key": "objectives_for_family",
          "label": "Objectives – For Family",
          "type": "textarea",
          "hint": "List the objectives aimed at the family's health outcomes",
          "required": true
        }
      ]
    },
    {
      "section": "General Examination",
      "fields": [
        {
          "key": "consciousness",
          "label": "Consciousness",
          "type": "dropdown",
          "options": ["Conscious", "Semi-conscious", "Unconscious"]
        },
        {
          "key": "orientation",
          "label": "Orientation",
          "type": "dropdown",
          "options": ["Oriented to time, place and person"]
        },
        {
          "key": "nourishment",
          "label": "Nourishment",
          "type": "dropdown",
          "options": ["Well-nourished", "Moderately nourished"]
        },
        {
          "key": "body_built",
          "label": "Body Built",
          "type": "dropdown",
          "options": ["Thin", "Moderate", "Obese"]
        },
        {
          "key": "activity",
          "label": "Activity",
          "type": "dropdown",
          "options": ["Active", "Dull"]
        },
        {
          "key": "look",
          "label": "Look",
          "type": "dropdown",
          "options": ["Pleasant", "Happy", "Alert", "Sad", "Depressed", "Fearful", "Anxious", "Tired"]
        },
        {
          "key": "speech",
          "label": "Speech",
          "type": "dropdown",
          "options": ["Clear", "Sluring", "Stammering", "Maintains eye contact"]
        }
      ]
    },
    {
      "section": "Anthropometric Measurement",
      "fields": [
        {
          "key": "anthropometric",
          "label": "Anthropometric measurement",
          "type": "textbox",
          "placeholder": "Enter anthropometric measurement"
        },
        {
          "key": "height",
          "label": "Height",
          "type": "textbox",
          "placeholder": "Enter height"
        },
        {
          "key": "weight",
          "label": "Weight",
          "type": "textbox",
          "placeholder": "Enter weight"
        },
        {
          "key": "bmi",
          "label": "Bmi : Weight in kg/ height in m2",
          "type": "textbox",
          "placeholder": "Enter BMI"
        }
      ]
    },
    {
      "section": "Vital Signs",
      "fields": [
        {
          "key": "vital_signs",
          "label": "Vital signs",
          "type": "textbox",
          "placeholder": "Enter vital signs"
        },
        {
          "key": "temperature",
          "label": "Temperature: 0C /0F",
          "type": "textbox",
          "placeholder": "Enter temperature"
        },
        {
          "key": "pulse",
          "label": "Pulse : Beats / min",
          "type": "textbox",
          "placeholder": "Enter pulse rate"
        },
        {
          "key": "respiration",
          "label": "Respiration Breaths / min",
          "type": "textbox",
          "placeholder": "Enter respiration rate"
        },
        {
          "key": "blood_pressure",
          "label": "Blood pressure mm of Hg",
          "type": "textbox",
          "placeholder": "Enter blood pressure"
        }
      ]
    },
    {
      "section": "A. Integumentary System — Skin",
      "fields": [
        {
          "key": "skin_colour",
          "label": "Skin Colour",
          "type": "dropdown",
          "options": ["Fair", "Brown", "Dark in complexion"]
        },
        {
          "key": "skin_texture",
          "label": "Skin Texture",
          "type": "dropdown",
          "options": ["Normal", "Dry"]
        },
        {
          "key": "skin_turgor",
          "label": "Skin Turgor",
          "type": "dropdown",
          "options": ["Normal", "Decreased"]
        },
        {
          "key": "discolouration",
          "label": "Discolouration",
          "type": "dropdown",
          "options": ["Absent", "Yellowish", "Cyanosis", "Vitiligo", "Increased pigmentation", "Pallor"]
        },
        {
          "key": "lesions_masses",
          "label": "Lesions / Masses",
          "type": "dropdown",
          "options": ["Absent", "Macule", "Papule", "Nodule", "Vesicle", "Bullae", "Plaque", "Cyst", "Erosion", "Abrasion", "Ulcer", "Fissure", "Crust", "Scar", "Keloid", "Erythema", "Pustule", "Wheal"]
        },
        {
          "key": "skin_subjective",
          "label": "Subjective Symptoms",
          "type": "dropdown",
          "options": ["No complaints", "Pruritis", "Pain", "Feeling of cold", "Warmth", "Tingling", "Numbness"]
        }
      ]
    },
    {
      "section": "A. Integumentary System — Nail",
      "fields": [
        {
          "key": "nail_observation",
          "label": "On Observation",
          "type": "dropdown",
          "options": ["Intact", "Onchylosis", "Peeling or cracked"]
        },
        {
          "key": "nail_beds",
          "label": "Nail Beds",
          "type": "dropdown",
          "options": ["Pink", "Cyanosed", "Pale"]
        },
        {
          "key": "nail_plate",
          "label": "Nail Plate",
          "type": "dropdown",
          "options": ["Flat", "Clubbing", "Whitening"]
        },
        {
          "key": "capillary_refill",
          "label": "Capillary Refill (Seconds)",
          "type": "textbox",
          "placeholder": "Enter seconds"
        },
        {
          "key": "nail_cyanosis",
          "label": "Cyanosis",
          "type": "dropdown",
          "options": ["Absent", "Present (specify)"]
        },
        {
          "key": "nail_cyanosis_specify",
          "label": "If Present, Specify",
          "type": "textbox",
          "placeholder": "Specify cyanosis details",
          "conditional_on": { "field": "nail_cyanosis", "value": "Present (specify)" }
        }
      ]
    },
    {
      "section": "A. Integumentary System — Hair",
      "fields": [
        {
          "key": "hair_colour",
          "label": "Hair Colour",
          "type": "dropdown",
          "options": ["Black", "Brown", "Red", "Grey"]
        },
        {
          "key": "hair_texture",
          "label": "Hair Texture",
          "type": "dropdown",
          "options": ["Normal", "Dry"]
        },
        {
          "key": "hair_grooming",
          "label": "Grooming",
          "type": "dropdown",
          "options": ["Not groomed", "Well groomed"]
        },
        {
          "key": "hair_distribution",
          "label": "Distribution",
          "type": "dropdown",
          "options": ["Normal", "Scanty", "Bald", "Alopecia"]
        }
      ]
    },
    {
      "section": "B. Head",
      "fields": [
        {
          "key": "head_shape",
          "label": "Shape",
          "type": "dropdown",
          "options": ["Normal cephalic", "Micro cephalic", "Macro cephalic", "Hydro cephalic"]
        },
        {
          "key": "scalp",
          "label": "Scalp",
          "type": "dropdown",
          "options": ["Clean", "Pediculosis", "Presence of dandruff"]
        },
        {
          "key": "face",
          "label": "Face",
          "type": "dropdown",
          "options": ["Normal", "Puffiness", "Moon face", "Bell's palsy"]
        }
      ]
    },
    {
      "section": "C. Eyes",
      "fields": [
        {
          "key": "eye_brows",
          "label": "Eye Brows",
          "type": "dropdown",
          "options": ["Symmetrical", "Asymmetrically distributed", "Scanty"]
        },
        {
          "key": "eye_lashes_lids",
          "label": "Eye Lashes / Eye Lids",
          "type": "dropdown",
          "options": ["Equally distributed / Normal", "Oedematous", "Ptosis"]
        },
        {
          "key": "pupillary_reflex",
          "label": "Pupillary Reflex",
          "type": "dropdown",
          "options": ["PERRLA", "Unequal reaction to light"]
        },
        {
          "key": "pupil_shape",
          "label": "Pupil Shape",
          "type": "dropdown",
          "options": ["Round", "Oval", "Yellowish in colour"]
        },
        {
          "key": "conjunctiva",
          "label": "Conjunctiva",
          "type": "dropdown",
          "options": ["Normal", "Pale", "Yellowish", "Red", "Flushed"]
        },
        {
          "key": "vision",
          "label": "Vision",
          "type": "dropdown",
          "options": ["Normal", "Abnormal (specify)"]
        },
        {
          "key": "vision_specify",
          "label": "If Abnormal, Specify (including use of spectacles)",
          "type": "textbox",
          "placeholder": "Specify vision abnormality",
          "conditional_on": { "field": "vision", "value": "Abnormal (specify)" }
        },
        {
          "key": "corneal_reflex",
          "label": "Corneal Reflex",
          "type": "dropdown",
          "options": ["Present", "Absent"]
        },
        {
          "key": "eye_subjective",
          "label": "Subjective Symptoms",
          "type": "dropdown",
          "options": ["No complaints", "Pain", "Itching", "Increased production of tears", "Decreased production of tears"]
        }
      ]
    },
    {
      "section": "D. Ears",
      "fields": [
        {
          "key": "pinna",
          "label": "Pinna",
          "type": "dropdown",
          "options": ["Normally placed", "Anotia", "Microtia", "Macrotia"]
        },
        {
          "key": "cerumen",
          "label": "Cerumen",
          "type": "dropdown",
          "options": ["Canal is clear", "Blocked"]
        },
        {
          "key": "otorrhoea",
          "label": "Otorrhoea",
          "type": "dropdown",
          "options": ["Absent", "Purulent", "Serous", "Blood", "Sanguinous"]
        },
        {
          "key": "hearing",
          "label": "Hearing",
          "type": "dropdown",
          "options": ["Normal", "Decreased", "Hearing loss"]
        },
        {
          "key": "ear_subjective",
          "label": "Subjective Symptoms",
          "type": "dropdown",
          "options": ["No complaints", "Otalgia", "Tinnitus", "Vertigo"]
        }
      ]
    },
    {
      "section": "E. Nose",
      "fields": [
        {
          "key": "nasal_septum",
          "label": "Nasal Septum",
          "type": "dropdown",
          "options": ["Midline", "Deviated"]
        },
        {
          "key": "nasal_pathway",
          "label": "Nasal Pathway",
          "type": "dropdown",
          "options": ["Patent", "Obstructed", "Nasal polyp"]
        },
        {
          "key": "smell",
          "label": "Smell",
          "type": "dropdown",
          "options": ["Normal", "Absent"]
        },
        {
          "key": "nasal_discharge",
          "label": "Nasal Discharge",
          "type": "dropdown",
          "options": ["Absent", "Watery", "Purulent", "Mucoid", "Epistaxis"]
        },
        {
          "key": "frontal_maxillary_sinuses",
          "label": "Frontal / Maxillary Sinuses",
          "type": "dropdown",
          "options": ["Absent", "Painful", "Tender"]
        }
      ]
    },
    {
      "section": "Mouth and Pharynx",
      "fields": [
        {
          "key": "lips_colour",
          "label": "Lips Colour",
          "type": "dropdown",
          "options": ["Pink", "Pale", "Dark"]
        },
        {
          "key": "lips_symmetry",
          "label": "Lips Symmetry",
          "type": "dropdown",
          "options": ["Symmetrical", "Asymmetrical"]
        },
        {
          "key": "gums",
          "label": "Gums",
          "type": "dropdown",
          "options": ["Pink in colour", "Bleeding", "Swollen", "Spongy"]
        },
        {
          "key": "teeth_colour",
          "label": "Teeth Colour",
          "type": "dropdown",
          "options": ["White", "Yellowish", "Stains"]
        },
        {
          "key": "dental_caries",
          "label": "Dental Caries",
          "type": "dropdown",
          "options": ["Absent", "Present"]
        },
        {
          "key": "no_of_teeth",
          "label": "Number of Teeth",
          "type": "textbox",
          "placeholder": "Enter number of teeth"
        },
        {
          "key": "mucus_membrane",
          "label": "Mucus Membrane",
          "type": "dropdown",
          "options": ["Pink in colour / Moist", "Dry", "Lesions (specify)"]
        },
        {
          "key": "mucus_membrane_specify",
          "label": "If Lesions, Specify",
          "type": "textbox",
          "placeholder": "Specify lesions",
          "conditional_on": { "field": "mucus_membrane", "value": "Lesions (specify)" }
        },
        {
          "key": "breath_odour",
          "label": "Breath Odour (Halitosis)",
          "type": "dropdown",
          "options": ["Absent", "Present"]
        },
        {
          "key": "gag_reflex",
          "label": "Gag Reflex",
          "type": "dropdown",
          "options": ["Present", "Absent"]
        },
        {
          "key": "tonsils",
          "label": "Tonsils",
          "type": "dropdown",
          "options": ["Not enlarged", "Enlarged", "Painful"]
        },
        {
          "key": "voice",
          "label": "Voice",
          "type": "dropdown",
          "options": ["Clear", "Harsh", "Aphonia", "Dysphonia"]
        },
        {
          "key": "mouth_subjective",
          "label": "Subjective Symptoms",
          "type": "dropdown",
          "options": ["No complaints", "Toothache", "Dysphagia", "Odynophagia", "Throat pain"]
        }
      ]
    },
    {
      "section": "Neck",
      "fields": [
        {
          "key": "neck_rom",
          "label": "Range of Motion",
          "type": "dropdown",
          "options": ["Possible", "Painful", "Absent"]
        },
        {
          "key": "lymph_node",
          "label": "Lymph Node",
          "type": "dropdown",
          "options": ["Not enlarged", "Enlarged", "Painful"]
        },
        {
          "key": "lymph_node_size",
          "label": "Lymph Node Size",
          "type": "textbox",
          "placeholder": "Specify size if enlarged"
        },
        {
          "key": "trachea",
          "label": "Trachea",
          "type": "dropdown",
          "options": ["Midline", "Deviation"]
        },
        {
          "key": "thyroid_gland",
          "label": "Thyroid Gland",
          "type": "dropdown",
          "options": ["Not enlarged", "Enlarged", "Removed"]
        },
        {
          "key": "jugular_vein",
          "label": "Jugular Vein",
          "type": "dropdown",
          "options": ["Not distended", "Distended"]
        }
      ]
    },
    {
      "section": "H. Cardiorespiratory System",
      "fields": [
        {
          "key": "thorax",
          "label": "Thorax",
          "type": "dropdown",
          "options": ["Symmetrical", "Asymmetrical", "Pectus carinatum", "Barrel chest"]
        },
        {
          "key": "thorax_expansion",
          "label": "Thorax Expansion",
          "type": "dropdown",
          "options": ["Normal / Symmetrical", "Delayed", "Shallow"]
        },
        {
          "key": "heart_sounds",
          "label": "Heart Sounds",
          "type": "dropdown",
          "options": ["S1, S2", "Murmur", "Gallop sound"]
        },
        {
          "key": "breath_sounds",
          "label": "Breath Sounds",
          "type": "dropdown",
          "options": ["Normal", "Wheeze", "Friction", "Rhonchi", "Crackles", "Stridor"]
        },
        {
          "key": "apical_pulse",
          "label": "Apical Pulse (Beats/min)",
          "type": "textbox",
          "placeholder": "Enter apical pulse"
        },
        {
          "key": "cough",
          "label": "Cough",
          "type": "dropdown",
          "options": ["Absent", "Dry", "Whooping", "Productive"]
        },
        {
          "key": "sputum_present",
          "label": "Sputum",
          "type": "dropdown",
          "options": ["Absent", "Present"]
        },
        {
          "key": "sputum_consistency",
          "label": "Sputum Consistency",
          "type": "dropdown",
          "options": ["Mucoid", "Frothy", "Rusty", "Sticky", "Purulent", "Bad odour"],
          "conditional_on": { "field": "sputum_present", "value": "Present" }
        },
        {
          "key": "sputum_colour",
          "label": "Sputum Colour",
          "type": "dropdown",
          "options": ["Green", "Yellow", "Blood stained"],
          "conditional_on": { "field": "sputum_present", "value": "Present" }
        },
        {
          "key": "cardio_subjective",
          "label": "Subjective Symptoms",
          "type": "dropdown",
          "options": ["No complaints", "Diaphoresis", "Breathless", "Giddiness", "Palpitation", "Chest pain", "Shoulder pain", "Chest tightness", "Heart burn", "Exercise intolerance"]
        }
      ]
    },
    {
      "section": "I. Breast & Axilla",
      "fields": [
        {
          "key": "breast_symmetry",
          "label": "Symmetry",
          "type": "dropdown",
          "options": ["Symmetrical", "Asymmetrical"]
        },
        {
          "key": "nipple",
          "label": "Nipple",
          "type": "dropdown",
          "options": ["Normal", "Retracted", "Inverted"]
        },
        {
          "key": "nipple_colour",
          "label": "Nipple Colour",
          "type": "textbox",
          "placeholder": "Enter nipple colour"
        },
        {
          "key": "breast_discharge",
          "label": "Discharge",
          "type": "dropdown",
          "options": ["Absent", "Milky", "Yellowish", "Purulent"]
        },
        {
          "key": "breast_lesions",
          "label": "Lesions / Masses",
          "type": "dropdown",
          "options": ["Absent", "Ulceration", "Nodes", "Swelling (moving)", "Swelling (painful/tender)"]
        },
        {
          "key": "axillary_nodes",
          "label": "Axillary Nodes",
          "type": "dropdown",
          "options": ["Not palpable", "Palpable / Moving", "Painful"]
        },
        {
          "key": "breast_hair",
          "label": "Hair Distribution",
          "type": "dropdown",
          "options": ["Well distributed", "Scanty"]
        }
      ]
    },
    {
      "section": "J. Abdomen",
      "fields": [
        {
          "key": "abdomen_inspection",
          "label": "On Inspection",
          "type": "dropdown",
          "options": ["Flat", "Linea nigra", "Distention", "Scar", "Hernia", "Peristaltic movement visible"]
        },
        {
          "key": "umbilicus",
          "label": "Umbilicus",
          "type": "dropdown",
          "options": ["Clean", "Everted"]
        },
        {
          "key": "bowel_sounds",
          "label": "On Auscultation — Bowel Sounds",
          "type": "dropdown",
          "options": ["Present", "Absent", "Murmurs"]
        },
        {
          "key": "percussion",
          "label": "On Percussion",
          "type": "dropdown",
          "options": ["Fluid not detected", "Fluid detected", "Masses detected", "Air detected"]
        },
        {
          "key": "palpation",
          "label": "On Palpation",
          "type": "dropdown",
          "options": ["Soft", "Tender"]
        },
        {
          "key": "liver",
          "label": "Liver",
          "type": "dropdown",
          "options": ["Non palpable", "Palpable"]
        },
        {
          "key": "spleen",
          "label": "Spleen",
          "type": "dropdown",
          "options": ["Non palpable", "Palpable"]
        },
        {
          "key": "abdomen_masses",
          "label": "Masses",
          "type": "dropdown",
          "options": ["Non palpable", "Palpable"]
        },
        {
          "key": "abdomen_subjective",
          "label": "Subjective Symptoms",
          "type": "dropdown",
          "options": ["No complaints", "Nausea", "Vomiting", "Heart burn", "Abdominal cramps", "Polyphagia"]
        }
      ]
    },
    {
      "section": "K. Musculoskeletal",
      "fields": [
        {
          "key": "postural_curves",
          "label": "Postural Curves",
          "type": "dropdown",
          "options": ["Normal", "Kyphosis", "Lordosis", "Scoliosis"]
        },
        {
          "key": "muscle_tone",
          "label": "Muscle Tone",
          "type": "dropdown",
          "options": ["Normal", "Hypertonia", "Hypotonia", "Flaccid", "Spasticity", "Rigidity"]
        },
        {
          "key": "muscle_strength",
          "label": "Muscle Strength",
          "type": "dropdown",
          "options": ["Normal", "Active", "Hyperactive", "Weaker than normal"]
        }
      ]
    },
    {
      "section": "L. Upper Extremities",
      "fields": [
        {
          "key": "upper_symmetry",
          "label": "Symmetry",
          "type": "dropdown",
          "options": ["Symmetrical", "Asymmetrical"]
        },
        {
          "key": "upper_rom",
          "label": "Range of Motion",
          "type": "dropdown",
          "options": ["Possible", "Not possible (specify)"]
        },
        {
          "key": "upper_rom_specify",
          "label": "If Not Possible, Specify",
          "type": "textbox",
          "placeholder": "Specify ROM limitation",
          "conditional_on": { "field": "upper_rom", "value": "Not possible (specify)" }
        },
        {
          "key": "radial_pulse",
          "label": "Peripheral Pulse (Radial)",
          "type": "dropdown",
          "options": ["Normal rate and rhythm", "Abnormal (specify)"]
        },
        {
          "key": "radial_pulse_specify",
          "label": "If Abnormal, Specify",
          "type": "textbox",
          "placeholder": "Specify abnormality",
