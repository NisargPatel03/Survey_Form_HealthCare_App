        },
        {
          "key": "upper_reflexes",
          "label": "Reflexes (Biceps / Triceps)",
          "type": "dropdown",
          "options": ["Normal", "Abnormal (specify)"]
        },
        {
          "key": "upper_reflexes_specify",
          "label": "If Abnormal, Specify Reflexes",
          "type": "textbox",
          "placeholder": "Specify abnormal reflexes",
          "conditional_on": { "field": "upper_reflexes", "value": "Abnormal (specify)" }
        },
        {
          "key": "upper_swelling",
          "label": "Swelling",
          "type": "dropdown",
          "options": ["Absent", "Present (specify area)"]
        },
        {
          "key": "upper_swelling_specify",
          "label": "Specify Swelling Area",
          "type": "textbox",
          "placeholder": "Specify area",
          "conditional_on": { "field": "upper_swelling", "value": "Present (specify area)" }
        },
        {
          "key": "upper_cyanosis",
