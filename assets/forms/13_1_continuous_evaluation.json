              "type": "dropdown",
              "options": ["1 - Poor", "2 - Satisfactory / Fair", "3 - Good", "4 - Very Good"],
              "max_marks": 4
            },
            "recording_and_reporting": {
              "label": "g) Recording and Reporting",
