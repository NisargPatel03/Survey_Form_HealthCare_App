{
  "title": "Continuous Evaluation of Performance in Community",
  "institution": "Manikaka Topawala Institute of Nursing, CHARUSAT – Community Health Nursing",
  "sections": [
    {
      "section": "Student & Experience Details",
      "fields": [
        { "key": "student_name", "label": "Name of Student", "type": "text", "required": true },
        { "key": "student_id", "label": "Student ID No.", "type": "text", "required": true },
        { "key": "area_of_experience", "label": "Area of Experience", "type": "text", "required": true },
        { "key": "period_of_experience", "label": "Period of Experience", "type": "text", "hint": "e.g. 01/06/2024 to 15/06/2024", "required": true }
      ]
    },
    {
      "section": "Evaluation Criteria",
      "description": "Scores: 4 = Very Good, 3 = Good, 2 = Satisfactory / Fair, 1 = Poor",
      "fields": [
        {
          "key": "personal_and_professional_qualities",
          "label": "I. Personal and Professional Qualities",
          "type": "object",
          "required": true,
          "properties": {
            "leadership": {
              "label": "a) Leadership",
              "type": "dropdown",
              "options": ["1 - Poor", "2 - Satisfactory / Fair", "3 - Good", "4 - Very Good"],
              "max_marks": 4
            },
            "punctuality": {
              "label": "b) Punctuality",
              "type": "dropdown",
              "options": ["1 - Poor", "2 - Satisfactory / Fair", "3 - Good", "4 - Very Good"],
              "max_marks": 4
            },
            "grooming": {
              "label": "c) Grooming",
              "type": "dropdown",
              "options": ["1 - Poor", "2 - Satisfactory / Fair", "3 - Good", "4 - Very Good"],
              "max_marks": 4
            },
            "relationship_with_others": {
              "label": "d) Relationship with Others",
              "type": "dropdown",
              "options": ["1 - Poor", "2 - Satisfactory / Fair", "3 - Good", "4 - Very Good"],
              "max_marks": 4
            },
            "attitude_towards_suggestions": {
              "label": "e) Attitude Towards Suggestions",
              "type": "dropdown",
              "options": ["1 - Poor", "2 - Satisfactory / Fair", "3 - Good", "4 - Very Good"],
              "max_marks": 4
            }
          }
        },
