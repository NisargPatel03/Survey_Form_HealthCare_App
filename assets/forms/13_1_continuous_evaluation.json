          "label": "V. Evaluation",
          "type": "object",
          "required": true,
          "properties": {
            "health_teaching": {
              "label": "a) Health Teaching",
              "type": "dropdown",
              "options": ["1 - Poor", "2 - Satisfactory / Fair", "3 - Good", "4 - Very Good"],
